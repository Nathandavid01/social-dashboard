{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npx tsc --noEmit*)",
      "Bash(export PATH*&&*tsc --noEmit*)",
      "Bash(export PATH*&&*npx tsc*)",
      "Bash(open http://localhost:*)",

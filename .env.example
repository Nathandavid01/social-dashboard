# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (AI Chat) ───────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Metricool ─────────────────────────────────────────────────────────────────
# Found in: Metricool → Settings → API
METRICOOL_TOKEN=your-metricool-token
METRICOOL_USER_ID=your-user-id
METRICOOL_BLOG_ID=your-default-blog-id

# ── Cloudflare R2 (video storage) ─────────────────────────────────────────────
# Found in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=nmedia-videos
# Permanent PUBLIC base URL for FINAL (edited) videos only. The bucket stays
# private; public access is served by the Cloudflare Worker in
# infra/r2-public-edited-worker.js, which only exposes objects under /edited/.
# Set this to the Worker's domain (no trailing slash). Required for permanent
# links (e.g. pushing videos to Metricool). Unset keeps everything private.
# e.g. https://videos.natemedia.com
R2_PUBLIC_BASE_URL=

# ── ClickUp (optional — Video Queue integration) ──────────────────────────────
# Found in: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=your-clickup-token
CLICKUP_WEBHOOK_SECRET=your-webhook-secret

# ── Cron (background jobs) ────────────────────────────────────────────────────
# Bearer token the Vercel cron sends to /api/cron/metricool-sync, which pulls
# Metricool publish status into the board. Generate any long random string.
CRON_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (AI Chat) ───────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Metricool ─────────────────────────────────────────────────────────────────
# Found in: Metricool → Settings → API
METRICOOL_TOKEN=your-metricool-token
METRICOOL_USER_ID=your-user-id
METRICOOL_BLOG_ID=your-default-blog-id

# ── ClickUp (optional — Video Queue integration) ──────────────────────────────
# Found in: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=your-clickup-token
CLICKUP_WEBHOOK_SECRET=your-webhook-secret
